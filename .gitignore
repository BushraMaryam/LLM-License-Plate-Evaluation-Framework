__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore environment variables and secrets
.env
.env.local
.env.*.local

# Ignore virtual environments
venv/
env/

# Ignore logs and temporary files
*.log
logs/
debug.log

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore IDE/editor settings
.vscode/
.idea/
*.iml

# Ignore build and dist files
build/
dist/
*.egg-info/
